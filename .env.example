# ─── Required ─────────────────────────────────────────────────────────
# AI API key for email classification (get free from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# JWT secret for authentication (generate a random string, at least 32 characters)
# Example: openssl rand -hex 32
JWT_SECRET_KEY=change-me-to-a-random-secret-at-least-32-chars

# ─── Optional ─────────────────────────────────────────────────────────
# Database path (default: /app/data/phase1_tasks.db in Docker)
# DASHBOARD_DB_PATH=/app/data/phase1_tasks.db

# Email polling interval in minutes (default: 15)
# EMAIL_POLL_INTERVAL_MINUTES=15

# Server port (Railway sets this automatically)
# PORT=8000
